{% extends "layouts/main.html.twig" %}

{% block page_title %}Edit Advertisement{% endblock %}

{% block page_content %}
<div class="form-container">
    {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
    
    <div class="form-group">
        {{ form_label(form.title) }}
        {{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'Enter a catchy title for your ad'}}) }}
        {{ form_errors(form.title) }}
    </div>
    
    <div class="form-group">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-textarea', 'placeholder': 'Describe your item in detail...'}}) }}
        {{ form_errors(form.description) }}
    </div>
    
    <div class="form-group">
        {{ form_label(form.price) }}
        {{ form_widget(form.price, {'attr': {'class': 'form-control', 'placeholder': '0'}}) }}
        {{ form_errors(form.price) }}
    </div>
    
    <div class="form-group">
        {{ form_label(form.location) }}
        {{ form_widget(form.location, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Manchester, London, Birmingham'}}) }}
        {{ form_errors(form.location) }}
    </div>
    
    <div class="form-group">
        {{ form_label(form.category) }}
        {{ form_widget(form.category, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.category) }}
    </div>
    
    <div class="form-group">
        {{ form_label(form.quantity) }}
        {{ form_widget(form.quantity, {'attr': {'class': 'form-control', 'placeholder': '1'}}) }}
        {{ form_errors(form.quantity) }}
    </div>
    
    <div class="form-group">
        {{ form_label(form.imageFile, 'Product Image') }}
        {% if ad.imageUrl %}
            <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: 1rem;">
                <img src="{{ asset('uploads/ads/' ~ ad.imageUrl) }}" alt="Current image" style="max-width: 200px; border-radius: 8px;">
                <p style="color: var(--text-gray); font-size: 0.9rem; margin-top: 0.5rem;">Current image (upload a new one to replace)</p>
            </div>
        {% endif %}
        <div class="form-file" onclick="document.getElementById('{{ form.imageFile.vars.id }}').click()">
            {{ form_widget(form.imageFile, {'attr': {'onchange': 'previewImage(this)'}}) }}
            <div class="file-upload-icon"></div>
            <div class="file-upload-text">Click to upload a new image</div>
            <div class="file-upload-text" style="font-size: 0.85rem; margin-top: 0.5rem;">Supported: JPG, PNG, GIF (Max 5MB)</div>
        </div>
        <div style="display: flex; justify-content: center; margin-top: 1rem;">
            <img id="imagePreview" class="image-preview" style="display: none;">
        </div>
        {{ form_errors(form.imageFile) }}
    </div>
    
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" style="flex: 1;">Save Changes</button>
        <a href="{{ path('view_ad', {'id': ad.id}) }}" class="btn btn-secondary">Cancel</a>
    </div>
    
    {{ form_end(form) }}
</div>

<script>
function previewImage(input) {
    const preview = document.getElementById('imagePreview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
            preview.style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
    }
}
</script>
{% endblock %}