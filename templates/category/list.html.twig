{% extends "layouts/main.html.twig" %}

{% block page_title %}
  Category Management
{% endblock %}

{% block page_actions %}
    <a href="{{ path('category_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Category
    </a>
{% endblock %}

{% block page_content %}
    <div class="card shadow-sm">
        <div class="card-body">
            {% if categories|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 60px;">ID</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th style="width: 120px;" class="text-center">Ads Count</th>
                                <th style="width: 180px;" class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for category in categories %}
                                <tr>
                                    <td><small class="text-muted">#{{ category.id }}</small></td>
                                    <td>
                                        <strong>
                                            <i class="bi bi-folder" style="color: #007bff;"></i> 
                                            {{ category.name }}
                                        </strong>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            {{ category.description|length > 100 ? category.description|slice(0, 100) ~ '...' : category.description }}
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info" style="font-size: 0.9rem;">
                                            {{ category.ads|length }} ads
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div style="display: flex; gap: 5px; justify-content: center;">
                                            <a href="{{ path('category_view', {id: category.id}) }}" 
                                               style="padding: 5px 10px; background: #17a2b8; color: white; text-decoration: none; border-radius: 4px; font-size: 0.875rem;"
                                               title="View">
                                                 View
                                            </a>
                                            <a href="{{ path('category_edit', {id: category.id}) }}" 
                                               style="padding: 5px 10px; background: #ffc107; color: #000; text-decoration: none; border-radius: 4px; font-size: 0.875rem;"
                                               title="Edit">
                                                 Edit
                                            </a>
                                            <a href="{{ path('category_delete', {id: category.id}) }}" 
                                               style="padding: 5px 10px; background: #dc3545; color: white; text-decoration: none; border-radius: 4px; font-size: 0.875rem;"
                                               title="Delete"
                                               onclick="return confirm('Are you sure you want to delete this category?')">
                                                Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-center mt-4">
                    {{ knp_pagination_render(categories) }}
                </div>
            {% else %}
                <div class="text-center py-5">
                    <div style="font-size: 5rem; color: #dee2e6;">
                        <i class="bi bi-folder-x"></i>
                    </div>
                    <h5 class="text-muted mt-3">No categories found.</h5>
                    <p class="text-muted">Create your first category to start organizing advertisements.</p>
                    <a href="{{ path('category_new') }}" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Create First Category
                    </a>
                </div>
            {% endif %}
        </div>
    </div>
{% endblock %}

