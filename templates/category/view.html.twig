{% extends "layouts/main.html.twig" %}

{% block page_title %}
  {{ category.name }}
{% endblock %}

{% block page_actions %}
    <div class="btn-group" role="group">
        <a href="{{ path('category_list') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        <a href="{{ path('category_edit', {id: category.id}) }}" class="btn btn-warning">
            <i class="bi bi-pencil"></i> Edit
        </a>
        <a href="{{ path('category_delete', {id: category.id}) }}" 
           class="btn btn-danger"
           onclick="return confirm('Are you sure you want to delete this category?')">
            <i class="bi bi-trash"></i> Delete
        </a>
    </div>
{% endblock %}

{% block page_content %}
<div style="max-width: 1200px; margin: 0 auto;">
    <!-- Category ID Badge -->
    <div class="mb-3">
        <span class="badge bg-secondary" style="font-size: 0.9rem;">
            <i class="bi bi-hash"></i> Category ID: {{ category.id }}
        </span>
    </div>

    <!-- Category Information Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-info-circle"></i> Category Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-9">
                    <div class="mb-3">
                        <label class="text-muted small mb-1">CATEGORY NAME</label>
                        <h4 class="mb-0">{{ category.name }}</h4>
                    </div>
                    <div class="mb-3">
                        <label class="text-muted small mb-1">DESCRIPTION</label>
                        <p class="mb-0" style="line-height: 1.6;">{{ category.description }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Advertisements List Card -->
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-megaphone"></i> Advertisements in this Category
                </h5>
                {% if ads|length > 0 %}
                    <span class="badge bg-primary" style="font-size: 1rem;">{{ ads|length }} items</span>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            {% if ads|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 60px;">ID</th>
                                <th style="width: 80px;">Image</th>
                                <th>Title</th>
                                <th style="width: 120px;">Price</th>
                                <th style="width: 150px;">Location</th>
                                <th style="width: 100px;" class="text-center">Quantity</th>
                                <th style="width: 120px;" class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for ad in ads %}
                                <tr>
                                    <td><small class="text-muted">#{{ ad.id }}</small></td>
                                    <td>
                                        {% if ad.imageUrl %}
                                            <img src="{{ asset('uploads/ads/' ~ ad.imageUrl) }}" 
                                                 alt="{{ ad.title }}" 
                                                 style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px; border: 2px solid #e9ecef;">
                                        {% else %}
                                            <div style="width: 60px; height: 60px; background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%); display: flex; align-items: center; justify-content: center; border-radius: 8px;">
                                                <i class="bi bi-image" style="font-size: 1.5rem; color: #adb5bd;"></i>
                                            </div>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <strong>{{ ad.title }}</strong>
                                        <br>
                                        <small class="text-muted">{{ ad.description|length > 50 ? ad.description|slice(0, 50) ~ '...' : ad.description }}</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-success" style="font-size: 0.9rem;">£{{ ad.price|number_format }}</span>
                                    </td>
                                    <td>
                                        <i class="bi bi-geo-alt text-primary"></i> {{ ad.location }}
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-secondary">{{ ad.quantity }}</span>
                                    </td>
                                    <td class="text-center">
                                        <a href="{{ path('view_ad', {id: ad.id}) }}" 
                                           class="btn btn-sm btn-info" 
                                           title="View Ad">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-center mt-4">
                    {{ knp_pagination_render(ads) }}
                </div>
            {% else %}
                <div class="text-center py-5">
                    <div style="font-size: 5rem; color: #dee2e6;">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h5 class="text-muted mt-3">No advertisements in this category yet.</h5>
                    <p class="text-muted">When users create ads in this category, they will appear here.</p>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

