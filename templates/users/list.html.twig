{% extends "layouts/main.html.twig" %}

{% block page_title %}
  Users
{% endblock %}

{% block page_content %}
    {% if users|length > 0 %}
        <div class="users-grid">
            {% for user in users %}
                <div class="user-card">
                    <div class="user-card-body">
                        <h3 class="user-card-email">{{ user.email }}</h3>
                        <div class="user-card-roles">
                            {% for role in user.roles %}
                                <span class="badge badge-primary">{{ role }}</span>
                            {% endfor %}
                        </div>
                        {% if user.id != currentUser.id %}
                            <div class="user-card-actions">
                                <a href="{{ path('edit_user', {'id': user.id}) }}" class="btn btn-outline-primary btn-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;">
                                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                    </svg>
                                    Edit
                                </a>
                                <a href="{{ path('delete_user', {'id': user.id}) }}" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to delete this user?')">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                        <line x1="10" y1="11" x2="10" y2="17"></line>
                                        <line x1="14" y1="11" x2="14" y2="17"></line>
                                    </svg>
                                    Delete
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-state-icon"></div>
            <h2 class="empty-state-title">No Users Found</h2>
            <p class="empty-state-text">There are no users in the system yet.</p>
            <a href="{{ path('new_user') }}" class="btn btn-primary">Create First User</a>
        </div>
    {% endif %}
{% endblock %}
