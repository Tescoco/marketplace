{% extends "layouts/main.html.twig" %}

{% block page_title %}Create New User{% endblock %}

{% block page_content %}
<div class="form-container">
    {{ form_start(form) }}

    <div class="form-group">
        {{ form_label(form.email) }}
        {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'Enter email address'}}) }}
        {{ form_errors(form.email) }}
    </div>

    <div class="form-group">
        {{ form_label(form.roles) }}
        {{ form_widget(form.roles, {'attr': {'class': 'form-control'}}) }}
        {{ form_errors(form.roles) }}
    </div>

    <div class="form-group">
        {{ form_label(form.password) }}
        {{ form_widget(form.password, {'attr': {'class': 'form-control', 'placeholder': 'Enter password'}}) }}
        {{ form_errors(form.password) }}
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary" style="flex: 1;">Create User</button>
        <a href="{{ path('users') }}" class="btn btn-secondary">Cancel</a>
    </div>

    {{ form_end(form) }}
</div>
{% endblock %}
